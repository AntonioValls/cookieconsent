{
    "name": "@antoniovalls/cookieconsent",
    "version": "3.1.0",
    "description": "Cookie consent plugin personalizado (fork de vanilla-cookieconsent).",
    "main": "dist/cookieconsent.umd.js",
    "module": "dist/cookieconsent.esm.js",
    "files": [
        "dist",
        "types"
    ],
    "types": "types/index.d.ts",
    "scripts": {
        "dev": "rollup --config ./rollup-full.config.mjs --watch",
        "build": "pnpm rollup:full && pnpm rollup:core",
        "rollup:full": "rollup --config ./rollup-full.config.mjs",
        "rollup:core": "rollup --config ./rollup-core.config.mjs"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/AntonioValls/cookieconsent"
    },
    "keywords": [
        "cookie",
        "consent",
        "gdpr",
        "banner",
        "vanilla"
    ],
    "homepage": "https://github.com/AntonioValls/cookieconsent",
    "author": "Antonio Valls",
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@rollup/plugin-eslint": "^9.2.0",
        "@rollup/plugin-terser": "^1.0.0",
        "cssnano": "^7.1.7",
        "eslint": "^9.19.0",
        "globals": "^16.0.0",
        "postcss": "^8.5.10",
        "postcss-combine-duplicated-selectors": "^10.0.3",
        "rollup": "^4.60.2",
        "sass": "^1.99.0"
    }
}
